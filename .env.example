# ===== データベース =====
DATABASE_URL="file:./prisma/dev.db"

# ===== 認証 =====
# JWT署名鍵（本番では openssl rand -base64 32 等で生成した値に置き換える）
AUTH_SECRET="please-change-this-to-a-long-random-secret"
# セッション有効期間（秒）。既定 8 時間
SESSION_MAX_AGE="28800"

# 初期管理者（seed で投入）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="システム管理者"

# ===== メール送信（Nodemailer / SMTP）=====
# 未設定の場合は開発用 Ethereal アカウントに自動フォールバック（実際には届かずプレビューURLのみ）
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="助成金診断システム <noreply@example.com>"

# 相談予約案内に載せるURL（メール本文で使用）
BOOKING_URL="https://example.com/booking"

# ===== PDF =====
# 日本語フォント（TTF）の絶対 or プロジェクト相対パス。未配置だと日本語が文字化けします
PDF_FONT_PATH="assets/fonts/NotoSansJP-Regular.ttf"

# ===== アプリURL（メール内リンク用）=====
APP_BASE_URL="http://localhost:3000"
